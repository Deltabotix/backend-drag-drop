# Server port (default: 3000)
PORT=3000

# MySQL — backend DB (custom_blocks, etc.). Set these on Hostinger under Environment Variables.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=drag_and_drop

# Optional: Arduino CLI (for /upload/compile). On Hostinger set to your arduino-cli path.
# Hostinger example (use in Environment Variables panel):
# ARDUINO_CLI_PATH=/home/u610043941/bin/arduino-cli
# ARDUINO_HOME=/home/u610043941/Arduino
# Local dev (default): leave unset to use system 'arduino-cli' and ~/Arduino

